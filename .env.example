# URL do seu projeto (inclua https:// para evitar avisos)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Chave pública (anon/public) do Supabase (Project Settings -> API -> anon public)
# Observação: esta chave é usada no frontend.
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# ==========================
# API key do Resend (https://resend.com). Somente necessário se você habilitar envio de emails.
VITE_RESEND_API_KEY=
